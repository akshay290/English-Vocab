# Copy this file to .env and fill in your values
# Windows users: see WINDOWS_SETUP.md for step-by-step instructions

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/sscvocab

# Secret key for signing JWT tokens — must be at least 32 characters
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# API server port
PORT=8080

# Admin panel password (default shown below — change it if you want)
ADMIN_PASSWORD=sscvocab@admin2024

# Environment
NODE_ENV=development
